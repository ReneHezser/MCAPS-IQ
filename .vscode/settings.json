{
    "github.copilot.chat.cli.branchSupport.enabled": true,
    "github.copilot.chat.cli.sessionController.enabled": true,
    "github.copilot.chat.copilotMemory.enabled": false,

    // Prevent samples/lenvolk/.github/ customization files from leaking
    // into the parent workspace's Copilot context (prompts, instructions,
    // agents, skills). The subtree has its own full .github/ layer that
    // only applies when opened as its own workspace.
    "chat.promptFiles": {
        "samples/**": false
    },
    "chat.instructionsFilesLocations": {
        ".github/instructions": true,
        ".github/skills": true
    }
}