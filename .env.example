# Local environment configuration (created by `node scripts/init.js`)
# This file is gitignored — each user maintains their own copy.

# Absolute path to your Obsidian vault directory.
# Required for the OIL (Obsidian Intelligence Layer) MCP server.
# If not set, OIL won't start; workflows fall back to stateless CRM-only mode.
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
